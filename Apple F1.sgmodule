#!name=Apple F1 优化规则 (参数映射版)
#!desc=将所有 F1 流量映射到主配置的策略组。导入后请在模块设置中将目标指定为你的 Google 策略组。
#!author=Tan
#!system=ios, mac
#!argument=[TargetGroup:目标策略组]

[Rule]
# --- 所有 7 个地址全部走参数指定的策略组 ---
DOMAIN,linear.tv.apple.com,{{目标策略组}}
DOMAIN,play-edge.itunes.apple.com,{{目标策略组}}
DOMAIN,cma2.itunes.apple.com,{{目标策略组}}
DOMAIN,upp.itunes.apple.com,{{目标策略组}}
DOMAIN,tv.g.apple.com,{{目标策略组}}
DOMAIN-SUFFIX,formula1.com,{{目标策略组}}
DOMAIN-SUFFIX,f1-api.com,{{目标策略组}}
