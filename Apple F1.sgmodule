#!name=Apple F1 直连 Google 策略组
#!desc=将所有 Apple F1 相关的直播、授权、API 地址统一分流至主配置中的 Google 策略组。
#!author=Tan
#!system=ios, mac

[Rule]
# --- 所有 7 个地址统一走 Google 策略组 ---
DOMAIN,linear.tv.apple.com,Google
DOMAIN,play-edge.itunes.apple.com,Google
DOMAIN,cma2.itunes.apple.com,Google
DOMAIN,upp.itunes.apple.com,Google
DOMAIN,tv.g.apple.com,Google
DOMAIN-SUFFIX,formula1.com,Google
DOMAIN-SUFFIX,f1-api.com,Google
